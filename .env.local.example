# Resend API key for sending lead emails — https://resend.com/api-keys
RESEND_API_KEY=

# Inbox where leads should arrive
LEAD_TO_EMAIL=

# (Optional) sender address — must be a verified domain at Resend.
# Defaults to onboarding@resend.dev (Resend's sandbox sender) if unset.
LEAD_FROM_EMAIL=

# (Optional) Public URL of the deployed site — used for OG/canonical metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
